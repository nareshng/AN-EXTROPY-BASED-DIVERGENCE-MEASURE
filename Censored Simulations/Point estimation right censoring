  E2 = c(lambda1 = 1.0,  lambda2 = 2.0),
  E3 = c(lambda1 = 2.0,  lambda2 = 5.0),
  E4 = c(lambda1 = 1.0,  lambda2 = 0.5),
  E5 = c(lambda1 = 5.0,  lambda2 = 2.0),
  E6 = c(lambda1 = 10.0, lambda2 = 5.0)
)

# Weibull configurations

weibull_configs <- list(
  W1 = c(k1 = 0.5, scale1 = 1.0, k2 = 1.0, scale2 = 1.0),
  W2 = c(k1 = 1.0, scale1 = 1.0, k2 = 2.0, scale2 = 1.0),
  W3 = c(k1 = 2.0, scale1 = 1.0, k2 = 1.0, scale2 = 1.0),
  W4 = c(k1 = 1.5, scale1 = 1.0, k2 = 3.0, scale2 = 1.5),
