        k1 = cfg["k1"],
        scale1 = cfg["scale1"],
        k2 = cfg["k2"],
        scale2 = cfg["scale2"],
        n1 = nn[1],
        n2 = nn[2],
        censoring = cens,
        B = B
      )
      
      counter <- counter + 1L
    }
  }
}

final_results <- do.call(rbind, results)
rownames(final_results) <- NULL

# =============================================================================
# tables
# =============================================================================

make_wide_table <- function(df) {
  df$row_id <- paste0(df$config_id, " C", round(100 * df$target_censoring), "%")
  
  all_labels <- c(
    "E1", "E2", "E3", "E4", "E5", "E6",
    "W1", "W2", "W3", "W4", "W5", "W6"
  )
  
  df$config_num <- match(df$config_id, all_labels)
  df$cens_num <- round(100 * df$target_censoring)
  
  df <- df[order(df$config_num, df$cens_num), ]
  
  row_ids <- unique(df$row_id)
  
  size_order <- c(
    "(20, 20)",
    "(50, 50)",
    "(100, 100)",
    "(200, 200)"
  )
  
  sizes <- size_order[size_order %in% unique(df$sample_size)]
  
  wide <- data.frame(
    "Config / Censoring" = row_ids,
    check.names = FALSE,
    stringsAsFactors = FALSE
  )
  
  for (sz in sizes) {
    col_D <- paste0("D_KM_", sz)
    col_DCC <- paste0("DCC_KM_", sz)
    
    wide[[col_D]] <- NA_real_
    wide[[col_DCC]] <- NA_real_
    
    for (i in seq_along(row_ids)) {
      row <- df[df$row_id == row_ids[i] & df$sample_size == sz, ]
      
      if (nrow(row) == 1L) {
        wide[[col_D]][i] <- round(row$RelMSE_D_KM, 4)
        wide[[col_DCC]][i] <- round(row$RelMSE_DCC_KM, 4)
      }
    }
  }
  
  rownames(wide) <- NULL
  wide
}

exp_results <- subset(final_results, distribution == "Exponential")
weibull_results <- subset(final_results, distribution == "Weibull")

table_A <- make_wide_table(exp_results)
table_B <- make_wide_table(weibull_results)

